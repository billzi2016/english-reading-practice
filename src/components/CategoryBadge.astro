---
/**
 * 文件意图：集中维护文章分类徽章的文案和颜色，让分类样式不散落在首页和详情页中。
 *
 * 维护重点：
 *   - 分类配置只能来自 CATEGORY_CONFIG，新增分类时不要在本组件内加分支。
 *   - 组件只关心展示，不读取文章数据，保持职责单一。
 */
import type { Category } from '../types/index.ts';
import { CATEGORY_CONFIG } from '../config/categories.ts';

interface Props {
  category: Category;
}

const { category } = Astro.props;
const config = CATEGORY_CONFIG[category];
---

<span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${config.badgeClass}`}>
  {config.badgeLabel}
</span>

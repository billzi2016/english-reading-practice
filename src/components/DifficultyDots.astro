---
/**
 * 文件意图：渲染文章难度指示器，把难度等级和点数/颜色/文案的关系集中在一个组件里。
 *
 * 维护重点：
 *   - 调用方只传 difficulty，不需要知道具体点数和颜色。
 *   - 难度配置只能来自 difficulties.ts，新增难度时不要在本组件内加分支。
 */
import type { Difficulty } from '../types/index.ts';
import { DIFFICULTY_CONFIG, TOTAL_DIFFICULTY_DOTS } from '../config/difficulties.ts';

interface Props {
  difficulty: Difficulty;
}

const { difficulty } = Astro.props;
const config = DIFFICULTY_CONFIG[difficulty];
---

<div class="flex gap-1 items-center">
  {Array.from({ length: TOTAL_DIFFICULTY_DOTS }, (_, i) => (
    <span class={`dot ${i < config.filledCount ? config.colorClass : 'bg-slate-300 dark:bg-slate-600'}`}></span>
  ))}
  <span class="ml-1">{config.label}</span>
</div>
